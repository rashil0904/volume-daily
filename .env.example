# Copy this file to pipeline/.env and fill in your values before running.

# Zerodha Kite Connect
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_REDIRECT_URI=https://kite.trade/

# Screener.in
SCREENER_EMAIL=
SCREENER_PASSWORD=

# Upstox data token (long-lived, used by pipeline to fetch candles)
UPSTOX_ACCESS_TOKEN=

# Upstox trading — live
UPSTOX_LIVE_API_KEY=
UPSTOX_LIVE_API_SECRET=
UPSTOX_LIVE_REDIRECT_URI=http://127.0.0.1/

# Upstox sandbox static token
UPSTOX_SANDBOX_ACCESS_TOKEN=

# Default mode: live or sandbox
UPSTOX_MODE=live

# Telegram notifications (see @BotFather to create a bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
