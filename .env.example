# Copy this file to pipeline/.env and fill in your values before running.

# Zerodha Kite Connect
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_REDIRECT_URI=https://kite.trade/

# Screener.in
SCREENER_EMAIL=
SCREENER_PASSWORD=

# Upstox data token (long-lived, used by pipeline to fetch candles — analytics only, no trading)
UPSTOX_ACCESS_TOKEN=

# Telegram notifications (see @BotFather to create a bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
