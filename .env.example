# Copy this file to .env and fill in your values before running.

# Screener.in Premium account
SCREENER_EMAIL=your_email@example.com
SCREENER_PASSWORD=your_password

# Upstox API — expires daily, regenerate each morning:
# https://upstox.com/developer/api-documentation/authentication
UPSTOX_ACCESS_TOKEN=your_upstox_token_here

# Gmail sender (for notifications via notify.py)
# Use a Gmail App Password, not your regular password:
# Google Account > Security > 2-Step Verification > App passwords
SENDER_EMAIL=your_gmail@gmail.com
SENDER_APP_PASSWORD=your_16char_app_password
